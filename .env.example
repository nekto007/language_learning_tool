# ── Required ──────────────────────────────────────────────
# These must be set; app will refuse to start without them.
POSTGRES_USER=user
POSTGRES_PASSWORD=password
POSTGRES_DB=language_learning
POSTGRES_HOST=db
POSTGRES_PORT=5432
SECRET_KEY=your-secret-key-change-this
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"

# ── Security ──────────────────────────────────────────────
# JWT_SECRET_KEY must be set in production; in dev a random key is generated per restart.
JWT_SECRET_KEY=your-jwt-secret-key-here

# ── Recommended ───────────────────────────────────────────
FLASK_APP=run.py
FLASK_ENV=development
# FLASK_ENV values: development | production
# development: insecure cookies, random JWT fallback
# production : secure cookies, JWT_SECRET_KEY required

# ── Optional integrations ─────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=
TELEGRAM_BOT_USERNAME=llt_englishbot
# Set TELEGRAM_POLLING=true to run bot in polling mode (development only)
TELEGRAM_POLLING=

SITE_URL=https://example.com

GOOGLE_SITE_VERIFICATION=
GOOGLE_ANALYTICS_ID=

# ── Email (reminders / notifications) ────────────────────
# Leave blank to disable email sending.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=noreply@example.com
# SMTP_DEBUG_LEVEL: 0=off, 1=commands, 2=verbose
SMTP_DEBUG_LEVEL=0

# ── Rate limiting ─────────────────────────────────────────
# Storage backend for Flask-Limiter. "memory://" is fine for single-process dev;
# use "redis://localhost:6379/0" for multi-worker production.
RATELIMIT_STORAGE_URI=memory://

# ── Tuning ────────────────────────────────────────────────
REQUEST_TIMEOUT=10
MAX_RETRIES=3
MAX_PAGES=100

# Default timezone used as fallback when user has no timezone set.
DEFAULT_TIMEZONE=Europe/Moscow

# Queries slower than this threshold (ms) are logged as slow queries.
SLOW_QUERY_MS=100

# ── Testing (only for test runner) ────────────────────────
# TESTING=true
# DATABASE_URL=postgresql://user:password@localhost:5432/language_learning_test
